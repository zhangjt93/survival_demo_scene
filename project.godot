[layer_names]

3d_render/layer_1="default"
3d_render/layer_2="portal_surface"
3d_physics/layer_1="floor"
3d_physics/layer_2="character"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

anti_aliasing/quality/use_debanding=true
anti_aliasing/quality/use_taa=true
anti_aliasing/quality/msaa=0
